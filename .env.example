# LLM provider: "claude-agent-sdk" (local dev, subscription auth) | "openrouter" (deployed)
LLM_PROVIDER=claude-agent-sdk

# Only needed when LLM_PROVIDER=openrouter
OPENROUTER_API_KEY=
OPENROUTER_MODEL=deepseek/deepseek-chat

# Exa web search
EXA_API_KEY=

# Adzuna jobs API (optional). When both are set, Adzuna is used as a second
# structured source for listed jobs alongside Exa. When unset, search falls
# back to Exa alone. Free key: https://developer.adzuna.com/
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
